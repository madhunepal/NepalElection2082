---
export const prerender = false;
import { createClient } from '@supabase/supabase-js';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || process.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || process.env.PUBLIC_SUPABASE_ANON_KEY;
if (!supabaseUrl || !supabaseKey) throw new Error('Missing Supabase credentials');
const supabase = createClient(supabaseUrl, supabaseKey);

// ── Fetch Initial Data on Server ──────────────────────────────────
const { data: partySummaryData } = await supabase
  .from('party_summary')
  .select('*')
  .order('fptp_won', { ascending: false })
  .order('fptp_leading', { ascending: false })
  .order('pr_votes', { ascending: false });

const initialPartySummary = partySummaryData || [];

const { data: candidateResultsData } = await supabase
  .from('candidates')
  .select('candidate_id, name, party, district, constituency, total_votes_received, vote_percentage, status, last_updated')
  .or('total_votes_received.gt.0,status.neq.counting')
  .order('status', { ascending: true }) // won, then leading, etc.
  .order('total_votes_received', { ascending: false })
  .limit(50);

const initialCandidateResults = candidateResultsData || [];

function getStatusColor(status: string) {
  if (status.toLowerCase() === 'won') return 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 border-green-200 dark:border-green-800';
  if (status.toLowerCase() === 'leading') return 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 border-blue-200 dark:border-blue-800';
  return 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-400 border-gray-200 dark:border-gray-700';
}

function getStatusText(status: string) {
  if (status.toLowerCase() === 'won') return 'विजयी (Won)';
  if (status.toLowerCase() === 'leading') return 'अग्रता (Leading)';
  return 'गणना हुँदै (Counting)';
}
---

<html lang="ne">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>नतिजा (Results) | Nepal Election 2082</title>
    <meta name="description" content="Live election results for Nepal House of Representatives 2082." />
    <!-- Pass environment variables to client script -->
    <meta name="env-supabase-url" content={supabaseUrl} />
    <meta name="env-supabase-key" content={supabaseKey} />
    <script type="application/json" id="initial-party-summary" set:html={JSON.stringify(initialPartySummary)}></script>
  </head>
  <body class="bg-background min-h-screen font-sans antialiased text-foreground flex flex-col">
    
    <Header activeTab="result" />

    <main class="container mx-auto px-4 py-8 flex-1">
      <div class="mb-10 text-center">
        <h1 class="text-2xl sm:text-3xl md:text-5xl font-bold tracking-tight mb-4 flex flex-wrap items-center justify-center gap-2 md:gap-3">
          <span class="text-red-500 animate-pulse text-2xl md:text-4xl">🔴</span> 
          <span>Nepal House of Representatives 2082</span>
          <span class="text-base md:text-2xl font-normal text-muted-foreground hidden sm:inline">– Live Results</span>
        </h1>
        <p class="text-muted-foreground text-sm md:text-base max-w-2xl mx-auto">
          प्रत्यक्ष (FPTP) र समानुपातिक (PR) निर्वाचन प्रणालीको पछिल्लो मतपरिणाम।
        </p>
        
        <div class="flex items-center justify-center gap-4 mt-6">
          <p class="text-sm font-medium text-muted-foreground bg-secondary/50 px-4 py-2 rounded-full border border-border" id="last-updated-text">
            Last updated: <span class="font-mono text-foreground font-bold">{new Date().toLocaleTimeString()}</span>
          </p>
          <button 
            id="refresh-btn"
            class="inline-flex items-center justify-center w-10 h-10 md:w-auto md:px-4 md:py-2 bg-primary hover:bg-primary/90 text-primary-foreground text-sm font-medium rounded-full shadow-sm transition-all hover:scale-105 active:scale-95"
            title="Refresh Live Data"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 md:mr-2"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 21v-5h5"/></svg>
            <span class="hidden md:inline">Refresh Now</span>
          </button>
        </div>
      </div>

      <!-- Main Dashboard Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-12">
        
        <!-- Left Column: Party Leaderboard (all qualifying parties) -->
        <div class="lg:col-span-5 flex flex-col gap-6">
          <section>
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-2xl font-bold flex items-center gap-2 border-l-4 border-blue-600 pl-3">
                Party Leaderboard
              </h2>
              <span class="text-xs font-semibold text-muted-foreground uppercase tracking-wider bg-secondary px-2 py-1 rounded">FPTP Results</span>
            </div>
            
            <div class="flex flex-col gap-4" id="party-leaderboard">
              <!-- Rendered via JS -->
              {initialPartySummary.length === 0 && (
                <div class="text-center p-8 bg-card border border-border rounded-2xl">
                  <p class="text-muted-foreground">दलगत नतिजा उपलब्ध छैन।</p>
                </div>
              )}
            </div>
          </section>
        </div>

        <!-- Right Column: Proportional Votes (PR) -->
        <div class="lg:col-span-7">
          <section class="bg-card border border-border rounded-2xl p-4 sm:p-6 shadow-sm">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-1">
              <h3 class="font-bold text-base sm:text-lg flex items-center gap-2 border-l-4 border-purple-600 pl-3">
                🗳️ Proportional Votes (PR)
              </h3>
              <span class="text-xs sm:text-sm font-normal text-muted-foreground pl-5 sm:pl-0">110 PR seats</span>
            </div>
            <p class="text-xs sm:text-sm text-muted-foreground mb-4" id="pr-total-text">Total PR votes: loading...</p>
            
            <div id="pr-parties-container">
              <div class="text-center py-8 text-muted-foreground">
                <p class="text-sm">Loading PR data...</p>
              </div>
            </div>
          </section>
        </div>

      </div>

      <!-- Full-width: Constituency Results (All 165) -->
      <div class="mb-12">
        <section>
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
            <h2 class="text-2xl font-bold flex items-center gap-2 border-l-4 border-green-600 pl-3">
              Constituency Results
            </h2>
            <div class="flex items-center gap-3">
              <div class="relative">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground w-4 h-4 pointer-events-none">
                  <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                </svg>
                <input 
                  type="text" 
                  id="constituency-search" 
                  placeholder="Search by candidates or district"
                  class="pl-9 pr-4 py-2 text-sm bg-card border border-border rounded-lg w-full sm:w-[320px] focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 transition-all placeholder:text-muted-foreground/60"
                />
              </div>
              <span class="text-xs font-semibold text-muted-foreground uppercase tracking-wider bg-secondary px-2 py-1 rounded whitespace-nowrap" id="constituency-count-badge">All 165 Constituencies</span>
            </div>
          </div>

          <div class="flex flex-col gap-3" id="candidates-list-container">
            <!-- Rendered via JS -->
          </div>
        </section>
      </div>



    </main>

    <Footer />

    <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script is:inline>
      // ── Live Data API Endpoints ──────────────────────────────────
      const POLLING_INTERVAL = 60000; // 60 seconds for live data

      // ── Mock fallback data ──────────────────────────────────────
      const MOCK_PARTIES = [
        { party_name: 'Nepali Congress (NC)', fptp_leading: 12, fptp_won: 45, pr_votes: 1250000, pr_percentage: 28.5 },
        { party_name: 'CPN (UML)', fptp_leading: 8, fptp_won: 40, pr_votes: 1100000, pr_percentage: 25.1 },
        { party_name: 'Rastriya Swatantra Party (RSP)', fptp_leading: 15, fptp_won: 10, pr_votes: 950000, pr_percentage: 21.6 },
        { party_name: 'CPN (Maoist Centre)', fptp_leading: 5, fptp_won: 12, pr_votes: 500000, pr_percentage: 11.4 },
        { party_name: 'Rastriya Prajatantra Party', fptp_leading: 2, fptp_won: 5, pr_votes: 300000, pr_percentage: 6.8 }
      ];
      const MOCK_CANDIDATES = [
        { name: 'Gagan Kumar Thapa', party: 'Nepali Congress (NC)', district: 'Kathmandu', constituency: '4', total_votes_received: 25000, vote_percentage: 55.2, status: 'leading', candidate_id: null },
        { name: 'Rajan Bhattarai', party: 'CPN (UML)', district: 'Kathmandu', constituency: '4', total_votes_received: 22500, vote_percentage: 42.1, status: 'counting', candidate_id: null },
        { name: 'Rabi Lamichhane', party: 'Rastriya Swatantra Party (RSP)', district: 'Chitwan', constituency: '2', total_votes_received: 35000, vote_percentage: 68.5, status: 'won', candidate_id: null },
        { name: 'KP Sharma Oli', party: 'CPN (UML)', district: 'Jhapa', constituency: '5', total_votes_received: 38000, vote_percentage: 52.1, status: 'leading', candidate_id: null },
        { name: 'Pushpa Kamal Dahal', party: 'CPN (Maoist Centre)', district: 'Gorkha', constituency: '2', total_votes_received: 15000, vote_percentage: 45.0, status: 'leading', candidate_id: null },
        { name: 'Rajendra Lingden', party: 'Rastriya Prajatantra Party', district: 'Jhapa', constituency: '3', total_votes_received: 12000, vote_percentage: 25.5, status: 'counting', candidate_id: null }
      ];

      // ── Transform NepalVotes constituency data into party leaderboard ──
      function aggregatePartyData(constituencies) {
        const partyMap = {};
        let totalVotesAllParties = 0;

        constituencies.forEach(c => {
          if (!c.candidates || c.candidates.length === 0) return;

          // Find top candidate in this constituency
          const sorted = [...c.candidates].sort((a, b) => (b.votes || 0) - (a.votes || 0));
          const leader = sorted[0];

          c.candidates.forEach(cand => {
            const pName = cand.partyName || 'Independent';
            if (!partyMap[pName]) {
              partyMap[pName] = { party_name: pName, fptp_won: 0, fptp_leading: 0, pr_votes: 0, pr_percentage: 0 };
            }
            partyMap[pName].pr_votes += (cand.votes || 0);
            totalVotesAllParties += (cand.votes || 0);

            if (cand.isWinner) {
              partyMap[pName].fptp_won += 1;
            }
          });

          // Count leading (top candidate if not already winner and has votes)
          if (leader && leader.votes > 0 && !leader.isWinner) {
            const pName = leader.partyName || 'Independent';
            if (partyMap[pName]) {
              partyMap[pName].fptp_leading += 1;
            }
          }
        });

        // Calculate PR percentage
        const parties = Object.values(partyMap);
        if (totalVotesAllParties > 0) {
          parties.forEach(p => {
            p.pr_percentage = ((p.pr_votes / totalVotesAllParties) * 100);
          });
        }

        return parties;
      }

      // ── Transform NepalVotes constituency data into candidate list ──
      function flattenCandidates(constituencies) {
        const candidates = [];
        constituencies.forEach(c => {
          if (!c.candidates || c.candidates.length === 0) return;
          const sorted = [...c.candidates].sort((a, b) => (b.votes || 0) - (a.votes || 0));
          const leader = sorted[0];

          c.candidates.forEach(cand => {
            if (cand.votes <= 0) return; // Skip candidates with zero votes
            const isLeading = (cand === leader && cand.votes > 0 && !cand.isWinner);
            candidates.push({
              name: cand.nameNp || cand.name,
              party: cand.partyName || 'Independent',
              district: c.district || c.districtNp || '',
              constituency: c.name || '',
              total_votes_received: cand.votes || 0,
              vote_percentage: c.votesCast > 0 ? ((cand.votes / c.votesCast) * 100) : 0,
              status: cand.isWinner ? 'won' : (isLeading ? 'leading' : 'counting'),
              candidate_id: cand.candidateId || null
            });
          });
        });

        // Sort by votes descending, take top 20
        candidates.sort((a, b) => b.total_votes_received - a.total_votes_received);
        return candidates.slice(0, 20);
      }

      // ── Also try HamroPatro API as secondary source ──
      function transformHamroPatroData(data) {
        if (!data || !data.areas) return { parties: [], candidates: [] };
        
        const partyMap = {};
        const candidates = [];
        let totalVotesAll = 0;

        data.areas.forEach(area => {
          if (!area.result || !area.result.candidateResults) return;
          const results = area.result.candidateResults;
          const areaName = area.area ? (area.area.englishName || area.area.name) : '';

          results.forEach(cr => {
            const pName = cr.politicalPartyName || 'Independent';
            if (!partyMap[pName]) {
              partyMap[pName] = { party_name: pName, fptp_won: 0, fptp_leading: 0, pr_votes: 0, pr_percentage: 0 };
            }
            partyMap[pName].pr_votes += (cr.votes || 0);
            totalVotesAll += (cr.votes || 0);

            if (cr.winner) partyMap[pName].fptp_won += 1;
            else if (cr.leading) partyMap[pName].fptp_leading += 1;

            if (cr.votes > 0) {
              candidates.push({
                name: cr.candidateName || '',
                party: pName,
                district: areaName,
                constituency: areaName,
                total_votes_received: cr.votes || 0,
                vote_percentage: area.result.totalCountedVotes > 0 ? ((cr.votes / area.result.totalCountedVotes) * 100) : 0,
                status: cr.winner ? 'won' : (cr.leading ? 'leading' : 'counting'),
                candidate_id: cr.candidateId || null
              });
            }
          });
        });

        const parties = Object.values(partyMap);
        if (totalVotesAll > 0) {
          parties.forEach(p => { p.pr_percentage = (p.pr_votes / totalVotesAll) * 100; });
        }

        candidates.sort((a, b) => b.total_votes_received - a.total_votes_received);
        return { parties, candidates: candidates.slice(0, 20) };
      }

      // ── Main data fetching function ────────────────────────────
      async function fetchExternalData() {
        const btn = document.getElementById('refresh-btn');
        if (btn) btn.classList.add('opacity-50', 'pointer-events-none');

        let partyData = null;
        let candidateData = null;
        let isLive = false;

        try {
          // Fetch from our server-side proxy (bypasses CORS)
          console.log('[Live] Fetching from /api/live-data proxy...');
          const proxyRes = await fetch('/api/live-data', { cache: 'no-store' }).catch(() => null);
          
          if (proxyRes && proxyRes.ok) {
            const proxyData = await proxyRes.json().catch(() => null);
            
          if (proxyData && proxyData.constituencies && proxyData.constituencies.length > 0) {
              console.log('[Live] ' + proxyData.source + ': ' + proxyData.constituencies.length + ' constituencies loaded via proxy');
              partyData = aggregatePartyData(proxyData.constituencies);
              candidateData = proxyData.constituencies;
              isLive = true;
            }
          }
        } catch (err) {
          console.warn('[Live] Proxy fetch error, falling back to mock:', err);
        }


        // Fallback to mock data if both APIs failed
        if (!isLive || !partyData || partyData.length === 0) {
          console.log('[Fallback] Using mock data');
          partyData = MOCK_PARTIES;
          candidateData = MOCK_CANDIDATES;
          isLive = false;
        }

        // Render the data
        renderPartyLeaderboard(partyData);
        renderCandidatesList(candidateData);

        // Update timestamp with LIVE/MOCK indicator
        const updatedEl = document.getElementById('last-updated-text');
        if (updatedEl) {
          const badge = isLive
            ? '<span class="text-green-600 text-xs ml-2 border border-green-500 rounded px-1 font-bold">LIVE</span>'
            : '<span class="text-amber-500 text-xs ml-2 border border-amber-500 rounded px-1">MOCK</span>';
          updatedEl.innerHTML = 'Last updated: <span class="font-mono font-medium text-foreground">' + new Date().toLocaleTimeString() + '</span> ' + badge;
        }

        if (btn) {
          btn.classList.remove('opacity-50', 'pointer-events-none');
          const svg = btn.querySelector('svg');
          if (svg) {
            svg.classList.add('animate-spin');
            setTimeout(() => svg.classList.remove('animate-spin'), 600);
          }
        }
      }

      // ── Render functions ───────────────────────────────────────

      function renderPartyLeaderboard(partiesData) {
        const container = document.getElementById('party-leaderboard');
        if(!container) return;
        
        container.style.opacity = '0.5';
        container.style.transition = 'opacity 0.3s ease';

        setTimeout(() => {
          const parties = Array.isArray(partiesData) ? partiesData : [];
          // Show ALL parties with at least 1 won or 1 leading (including independents)
          const qualifyingParties = [...parties]
            .filter(p => (p.fptp_won || 0) >= 1 || (p.fptp_leading || 0) >= 1)
            .sort((a,b) => 
              ((b.fptp_won||0) * 1000 + (b.fptp_leading||0)) - ((a.fptp_won||0) * 1000 + (a.fptp_leading||0))
            );

          const rankColors = ['bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-500 border-yellow-200 dark:border-yellow-800', 
                              'bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-400 border-slate-200 dark:border-slate-700', 
                              'bg-orange-100 text-orange-800 dark:bg-orange-900/40 dark:text-orange-500 border-orange-200 dark:border-orange-800',
                              'bg-secondary text-secondary-foreground border-transparent',
                              'bg-secondary text-secondary-foreground border-transparent'];

          if (qualifyingParties.length === 0) {
            container.innerHTML = '<div class="text-center p-8 bg-card border border-border rounded-2xl"><p class="text-muted-foreground">Waiting for party data...</p></div>';
          } else {
            container.innerHTML = qualifyingParties.map((p, idx) => {
              return '<div class="bg-card border border-border rounded-2xl p-5 shadow-sm transform transition duration-300 hover:shadow-md relative overflow-hidden flex items-center gap-4">' +
                '<div class="absolute top-0 left-0 w-1 h-full bg-primary opacity-20"></div>' +
                '<div class="shrink-0 flex flex-col items-center justify-center w-10">' +
                  '<span class="text-sm font-bold text-muted-foreground uppercase mb-1">Rank</span>' +
                  '<div class="w-8 h-8 rounded-full border flex items-center justify-center font-bold text-sm ' + (rankColors[idx] || rankColors[4]) + '">' + (idx + 1) + '</div>' +
                '</div>' +
                '<div class="flex-1 min-w-0 border-l border-border pl-4">' +
                  '<h3 class="font-bold text-lg text-foreground truncate" title="' + p.party_name + '">' + p.party_name + '</h3>' +
                  '<p class="text-xs text-muted-foreground mt-0.5"><span class="font-medium">' + (p.pr_votes || 0).toLocaleString() + '</span> Total Votes (' + (p.pr_percentage != null ? parseFloat(p.pr_percentage).toFixed(2) + '%' : '0%') + ')</p>' +
                '</div>' +
                '<div class="shrink-0 flex gap-2 md:gap-4 text-center">' +
                  '<div class="bg-green-50 dark:bg-green-900/20 rounded-lg px-3 py-2 border border-green-100 dark:border-green-800/50 min-w-[60px]">' +
                    '<p class="text-[10px] font-bold text-green-600 dark:text-green-500 uppercase">Won</p>' +
                    '<p class="text-2xl font-black text-green-700 dark:text-green-400 leading-none mt-1">' + (p.fptp_won || 0) + '</p>' +
                  '</div>' +
                  '<div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg px-3 py-2 border border-blue-100 dark:border-blue-800/50 min-w-[60px]">' +
                    '<p class="text-[10px] font-bold text-blue-600 dark:text-blue-500 uppercase">Lead</p>' +
                    '<p class="text-2xl font-black text-blue-700 dark:text-blue-400 leading-none mt-1">' + (p.fptp_leading || 0) + '</p>' +
                  '</div>' +
                '</div>' +
              '</div>';
            }).join('');
          }

          container.style.opacity = '1';
        }, 300);
      }

      // ── Party color map for badges (matching candidates page) ──
      var PARTY_COLORS = {
        'नेपाली काँग्रेस': { bg: '#16a34a', text: '#fff', short: 'NC' },
        'नेपाल कम्युनिष्ट पार्टी (एकीकृत मार्क्सवादी लेनिनवादी)': { bg: '#dc2626', text: '#fff', short: 'UML' },
        'राष्ट्रिय स्वतन्त्र पार्टी': { bg: '#2563eb', text: '#fff', short: 'RSP' },
        'नेपाल कम्युनिष्ट पार्टी (माओवादी केन्द्र)': { bg: '#e11d48', text: '#fff', short: 'NCP' },
        'नेपाल कम्युनिस्ट पार्टी (माओवादी)': { bg: '#e11d48', text: '#fff', short: 'NCP' },
        'राष्ट्रिय प्रजातन्त्र पार्टी': { bg: '#7c3aed', text: '#fff', short: 'RPP' },
        'जनता समाजवादी पार्टी, नेपाल': { bg: '#ca8a04', text: '#fff', short: 'JSP' },
        'नेपाली काँग्रेस (समाजवादी)': { bg: '#22c55e', text: '#fff', short: 'NCS' },
        'लोकतान्त्रिक समाजवादी पार्टी, नेपाल': { bg: '#0284c7', text: '#fff', short: 'LSP' },
        'नागरिक उन्मुक्ति पार्टी': { bg: '#7c3aed', text: '#fff', short: 'NUP' },
        'जनमत पार्टी': { bg: '#0d9488', text: '#fff', short: 'JMP' },
        'राष्ट्रिय जनमोर्चा': { bg: '#be185d', text: '#fff', short: 'RJM' },
        'श्रम संस्कृति पार्टी': { bg: '#475569', text: '#fff', short: 'SSP' },
        'स्वतन्त्र': { bg: '#6b7280', text: '#fff', short: 'IND' }
      };

      function getPartyBadge(partyName) {
        var match = PARTY_COLORS[partyName];
        if (!match) {
          // Try partial match
          var keys = Object.keys(PARTY_COLORS);
          for (var i = 0; i < keys.length; i++) {
            if (partyName && partyName.indexOf(keys[i].substring(0, 8)) !== -1) { match = PARTY_COLORS[keys[i]]; break; }
          }
        }
        var bg = match ? match.bg : '#9e9e9e';
        var text = match ? match.text : '#fff';
        var short = match ? match.short : (partyName ? partyName.substring(0, 3) : '?');
        return '<span style="background:' + bg + ';color:' + text + '" class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold ml-1 whitespace-nowrap">' + short + '</span>';
      }

      // ── Province ordering: East (Koshi) to West (Sudurpashchim) ──
      var PROVINCE_ORDER = {
        'कोशी प्रदेश': 1, 'Koshi Province': 1, 'Province 1': 1, 'Koshi': 1,
        'मधेश प्रदेश': 2, 'Madhesh Province': 2, 'Province 2': 2, 'Madhesh': 2,
        'बागमती प्रदेश': 3, 'Bagmati Province': 3, 'Province 3': 3, 'Bagmati': 3,
        'गण्डकी प्रदेश': 4, 'Gandaki Province': 4, 'Province 4': 4, 'Gandaki': 4,
        'लुम्बिनी प्रदेश': 5, 'Lumbini Province': 5, 'Province 5': 5, 'Lumbini': 5,
        'कर्णाली प्रदेश': 6, 'Karnali Province': 6, 'Province 6': 6, 'Karnali': 6,
        'सुदूरपश्चिम प्रदेश': 7, 'Sudurpashchim Province': 7, 'Province 7': 7, 'Sudurpashchim': 7,
      };

      function getProvinceOrder(provinceName) {
        if (!provinceName) return 99;
        // Try exact match first
        if (PROVINCE_ORDER[provinceName] !== undefined) return PROVINCE_ORDER[provinceName];
        // Try partial match
        var keys = Object.keys(PROVINCE_ORDER);
        for (var i = 0; i < keys.length; i++) {
          if (provinceName.indexOf(keys[i]) !== -1 || keys[i].indexOf(provinceName) !== -1) {
            return PROVINCE_ORDER[keys[i]];
          }
        }
        return 99;
      }

      // ── Store global constituencies for search/filter ──
      var _allConstituencies = [];

      function renderCandidatesList(constituencies, searchTerm) {
        // If called with new data (not a search trigger), store it
        if (constituencies !== null && constituencies !== undefined) {
          _allConstituencies = Array.isArray(constituencies) ? constituencies : [];
        }

        var container = document.getElementById('candidates-list-container');
        if (!container) return;
        
        container.style.opacity = '0.5';
        container.style.transition = 'opacity 0.3s ease';

        setTimeout(function() {
          var items = _allConstituencies;
          var query = (searchTerm || '').trim().toLowerCase();

          // Filter by search term (match district, province, or candidate name)
          var filtered = items.filter(function(c) {
            if (!c.candidates || c.candidates.length === 0) return false;
            if (!query) return true;
            // Match district/province name (in both English and Nepali)
            var constName = ((c.district || '') + ' ' + (c.districtEn || '') + ' ' + (c.districtNp || '') + ' ' + (c.province || '')).toLowerCase();
            if (constName.indexOf(query) !== -1) return true;
            
            // Match candidate name (in both English and Nepali)
            for (var i = 0; i < c.candidates.length; i++) {
              var cand = c.candidates[i];
              var candName = ((cand.nameNp || '') + ' ' + (cand.name || '') + ' ' + (cand.partyName || '')).toLowerCase();
              if (candName.indexOf(query) !== -1) return true;
            }
            return false;
          });

          // Sort by Province order (Koshi → Sudurpashchim), then by constituency name
          var sorted = filtered.sort(function(a, b) {
            var pa = getProvinceOrder(a.province);
            var pb = getProvinceOrder(b.province);
            if (pa !== pb) return pa - pb;
            // Within same province, sort by constituency name
            var na = (a.name || a.code || '').toLowerCase();
            var nb = (b.name || b.code || '').toLowerCase();
            return na.localeCompare(nb);
          });

          // Update count badge
          var badge = document.getElementById('constituency-count-badge');
          if (badge) {
            badge.textContent = query ? (sorted.length + ' of ' + items.filter(function(c) { return c.candidates && c.candidates.length > 0; }).length + ' Constituencies') : ('All ' + sorted.length + ' Constituencies');
          }

          if (sorted.length === 0) {
            container.innerHTML = '<div class="text-center p-12 bg-card border border-border rounded-2xl"><h3 class="text-lg font-bold mb-2">मतगणना सुरू हुन बाँकी</h3><p class="text-muted-foreground">कुनै पनि क्षेत्रको मत विवरण प्राप्त भएको छैन।</p></div>';
          } else {
            // Build table header
            var header = '<div class="bg-card border border-border rounded-xl overflow-x-auto">' +
              '<table class="w-full text-left border-collapse min-w-[500px] sm:min-w-0">' +
              '<thead><tr class="bg-secondary/30 text-secondary-foreground border-b border-border text-[10px] sm:text-[11px] uppercase tracking-wider">' +
              '<th class="px-2 sm:px-4 py-2 sm:py-2.5 font-semibold">Constituency</th>' +
              '<th class="px-2 sm:px-4 py-2 sm:py-2.5 font-semibold">Key Candidates</th>' +
              '<th class="px-2 sm:px-4 py-2 sm:py-2.5 font-semibold text-right">Votes Cast</th>' +
              '</tr></thead><tbody>';

            var rows = sorted.map(function(c) {
              var cands = [...c.candidates].sort(function(a, b) { return (b.votes || 0) - (a.votes || 0); });
              var top3 = cands.slice(0, 3);
              var remaining = cands.length - 3;
              var totalVoters = c.totalVoters || 0;
              var votesCast = c.votesCast || 0;
              var countedPct = totalVoters > 0 ? ((votesCast / totalVoters) * 100).toFixed(1) : '0';
              var province = c.province || '';
              var district = c.district || c.districtNp || '';
              var constName = c.name || c.code || '';

              // Status badge
              var status = c.status || 'PENDING';
              var statusBadge = '';
              if (status === 'COMPLETED') statusBadge = '<span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 ml-2">DECLARED</span>';
              else if (status === 'COUNTING') statusBadge = '<span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400 ml-2">COUNTING</span>';
              else statusBadge = '<span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-secondary text-secondary-foreground ml-2">PENDING</span>';

              // Candidate rows
              var candHtml = top3.map(function(cand, ci) {
                var bullet = ci === 0 ? '🟢' : '🟡';
                if (cand.isWinner) bullet = '🏆';
                var name = cand.nameNp || cand.name || '';
                var badge = getPartyBadge(cand.partyName || '');
                return '<div class="flex items-center gap-1 py-0.5">' +
                  '<span class="text-xs">' + bullet + '</span>' +
                  '<span class="text-sm font-medium text-foreground truncate max-w-[140px] md:max-w-[200px]" title="' + name + '">' + name + '</span>' +
                  badge + '</div>';
              }).join('');

              if (remaining > 0) {
                candHtml += '<span class="text-[11px] text-muted-foreground">+' + remaining + ' more</span>';
              }

              // Votes cast column: show top 3 candidate votes with party color indicators
              var votesHtml = top3.map(function(cand) {
                var match = PARTY_COLORS[cand.partyName];
                var color = match ? match.bg : '#9e9e9e';
                var short = match ? match.short : '';
                return '<div class="flex items-center justify-end gap-1.5 py-0.5">' +
                  '<span class="text-[11px] text-muted-foreground">' + (short ? short + ' ' : '') + '</span>' +
                  '<span class="font-mono text-sm font-bold" style="color:' + color + '">' + (cand.votes || 0).toLocaleString() + '</span>' +
                  (cand.isWinner ? ' <span class="text-[10px]">🏆</span>' : '') +
                  '</div>';
              }).join('');

              // Counted percentage bar
              var pctNum = parseFloat(countedPct);
              var pctBar = votesCast > 0
                ? '<div class="mt-1"><div class="flex items-center justify-end gap-1"><span class="text-[10px] text-muted-foreground">' + countedPct + '% counted</span></div>' +
                  '<div class="w-full bg-secondary rounded-full h-1 mt-0.5"><div class="h-1 rounded-full transition-all ' + (pctNum >= 100 ? 'bg-green-500' : 'bg-blue-500') + '" style="width:' + Math.min(pctNum, 100) + '%"></div></div></div>'
                : '<div class="text-[10px] text-muted-foreground mt-1 text-right">– not started</div>';

              return '<tr class="border-b border-border/50 hover:bg-secondary/10 transition-colors">' +
                '<td class="px-2 sm:px-4 py-2 sm:py-3 align-top">' +
                  '<div class="font-bold text-xs sm:text-sm text-foreground">' + constName + statusBadge + '</div>' +
                  '<div class="text-[10px] sm:text-[11px] text-muted-foreground">' + province + ' · ' + district + '</div>' +
                '</td>' +
                '<td class="px-2 sm:px-4 py-2 sm:py-3 align-top">' + candHtml + '</td>' +
                '<td class="px-2 sm:px-4 py-2 sm:py-3 align-top text-right">' + votesHtml + pctBar + '</td>' +
              '</tr>';
            }).join('');

            container.innerHTML = header + rows + '</tbody></table></div>';
          }
          container.style.opacity = '1';
        }, 300);
      }

      // ── PR Data ──────────────────────────────────────────────
      const PR_API = '/api/pr-data';
      const TOTAL_PR_SEATS = 110;

      // Party color lookup matching Nepali party names to bar colors
      var PR_BAR_COLORS = {
        'राष्ट्रिय स्वतन्त्र पार्टी': '#2563eb',
        'नेपाली काँग्रेस': '#16a34a',
        'नेपाल कम्युनिष्ट पार्टी (एकीकृत मार्क्सवादी लेनिनवादी)': '#dc2626',
        'नेपाली कम्युनिष्ट पार्टी': '#e11d48',
        'राष्ट्रिय प्रजातन्त्र पार्टी': '#7c3aed',
        'श्रम संस्कृति पार्टी': '#ca8a04',
        'राष्ट्रिय परिवर्तन पार्टी': '#65a30d',
        'नेपाल मजदुर किसान पार्टी': '#0d9488',
        'जनता समाजवादी पार्टी, नेपाल': '#ea580c',
        'नागरिक उन्मुक्ति पार्टी': '#9333ea',
        'जनमत पार्टी': '#0891b2',
        'लोकतान्त्रिक समाजवादी पार्टी, नेपाल': '#0284c7',
        'नेपाल कम्युनिस्ट पार्टी (माओवादी केन्द्र)': '#be123c',
      };

      // English name map for better display
      var PR_ENGLISH_NAMES = {
        'राष्ट्रिय स्वतन्त्र पार्टी': 'Rastriya Swatantra Party',
        'नेपाली काँग्रेस': 'Nepali Congress',
        'नेपाल कम्युनिष्ट पार्टी (एकीकृत मार्क्सवादी लेनिनवादी)': 'CPN (Unified Marxist-Leninist)',
        'नेपाली कम्युनिष्ट पार्टी': 'Nepali Communist Party',
        'राष्ट्रिय प्रजातन्त्र पार्टी': 'Rastriya Prajatantra Party',
        'श्रम संस्कृति पार्टी': 'Shram Sanskriti Party',
        'राष्ट्रिय परिवर्तन पार्टी': 'Rastriya Parivartan Party',
        'नेपाल मजदुर किसान पार्टी': 'Nepal Workers and Peasants Party',
        'जनता समाजवादी पार्टी, नेपाल': 'Janata Samajbadi Party',
        'नागरिक उन्मुक्ति पार्टी': 'Nagarik Unmukti Party',
        'जनमत पार्टी': 'Janmat Party',
        'लोकतान्त्रिक समाजवादी पार्टी, नेपाल': 'Loktantrik Samajbadi Party',
        'नेपाल कम्युनिस्ट पार्टी (माओवादी केन्द्र)': 'CPN (Maoist Centre)',
      };

      async function fetchPRData() {
        try {
          var res = await fetch(PR_API, { cache: 'no-store' });
          if (!res.ok) throw new Error('PR fetch failed');
          var data = await res.json();
          if (!data || !data.parties || data.parties.length === 0) return;

          var totalVotes = data.totalPrVotes || 0;
          var parties = data.parties;

          // Sort by votes descending
          parties.sort(function(a, b) { return (b.prVotes || 0) - (a.prVotes || 0); });

          // Update total
          var totalEl = document.getElementById('pr-total-text');
          if (totalEl) {
            totalEl.innerHTML = 'Total PR votes: <span class="font-bold text-foreground font-mono">' + totalVotes.toLocaleString() + '</span>';
          }

          // Find max votes for bar scaling
          var maxVotes = parties[0]?.prVotes || 1;

          // Show parties with >2% vote share, aggregate rest as "Other"
          var aboveThreshold = parties.filter(function(p) { return p.prVotes > 0 && (p.voteShare > 2 || (totalVotes > 0 && ((p.prVotes / totalVotes) * 100) > 2)); });
          var belowThreshold = parties.filter(function(p) { return p.prVotes > 0 && !(p.voteShare > 2 || (totalVotes > 0 && ((p.prVotes / totalVotes) * 100) > 2)); });
          
          // Aggregate "Other" parties
          var otherVotes = 0;
          belowThreshold.forEach(function(p) { otherVotes += (p.prVotes || 0); });
          
          var filtered = aboveThreshold.slice();
          if (otherVotes > 0) {
            filtered.push({
              partyName: 'अन्य (Other)',
              prVotes: otherVotes,
              voteShare: totalVotes > 0 ? ((otherVotes / totalVotes) * 100) : 0,
              _isOther: true,
              _otherCount: belowThreshold.length
            });
          }
          var container = document.getElementById('pr-parties-container');
          if (!container) return;

          var html = filtered.map(function(party, idx) {
            var votes = party.prVotes || 0;
            var pct = party.voteShare ? party.voteShare.toFixed(1) : (totalVotes > 0 ? ((votes / totalVotes) * 100).toFixed(1) : '0');
            var barWidth = maxVotes > 0 ? ((votes / maxVotes) * 100).toFixed(1) : 0;
            var estSeats = totalVotes > 0 ? Math.round((votes / totalVotes) * TOTAL_PR_SEATS) : 0;
            var color = PR_BAR_COLORS[party.partyName] || '#6b7280';
            var engName = party._isOther ? 'Other (' + party._otherCount + ' parties)' : (PR_ENGLISH_NAMES[party.partyName] || party.partyName);

            // Dot color based on rank
            var dotColors = ['#2563eb', '#16a34a', '#f59e0b', '#dc2626', '#7c3aed', '#0d9488', '#ea580c', '#6b7280'];
            var dotColor = dotColors[idx % dotColors.length];

            return '<div class="py-4 ' + (idx < filtered.length - 1 ? 'border-b border-border/30' : '') + '">' +
              '<div class="flex items-center justify-between mb-1.5">' +
                '<div class="flex items-center gap-2.5">' +
                  '<span class="w-3 h-3 rounded-full flex-shrink-0" style="background:' + dotColor + '"></span>' +
                  '<div>' +
                    '<span class="font-semibold text-sm text-foreground">' + engName + '</span>' +
                    '<span class="text-[11px] text-muted-foreground ml-2">(' + party.partyName + ')</span>' +
                  '</div>' +
                '</div>' +
                '<div class="text-right flex-shrink-0 ml-4">' +
                  '<span class="font-bold text-base font-mono text-foreground">' + votes.toLocaleString() + '</span>' +
                  (!party._isOther ? '<span class="text-xs text-muted-foreground ml-2">' + estSeats + ' seats</span>' : '') +
                '</div>' +
              '</div>' +
              '<div class="flex items-center gap-3">' +
                '<div class="flex-1 h-3 bg-secondary rounded-full overflow-hidden">' +
                  '<div class="h-full rounded-full transition-all duration-700 ease-out" style="width:' + barWidth + '%;background:' + color + '"></div>' +
                '</div>' +
                '<span class="text-xs font-bold text-muted-foreground font-mono w-12 text-right">' + pct + '%</span>' +
              '</div>' +
            '</div>';
          }).join('');

          container.innerHTML = html;
        } catch (err) {
          console.warn('[PR] Fetch error:', err);
        }
      }

      // ── Initial execution ──────────────────────────────────────
      fetchExternalData();
      fetchPRData();
      document.getElementById('refresh-btn')?.addEventListener('click', function() {
        fetchExternalData();
        fetchPRData();
      });
      
      // Setup constituency search
      var searchInput = document.getElementById('constituency-search');
      if (searchInput) {
        var searchTimeout;
        searchInput.addEventListener('input', function(e) {
          clearTimeout(searchTimeout);
          searchTimeout = setTimeout(function() {
            renderCandidatesList(null, e.target.value);
          }, 300);
        });
      }

      console.log('[Polling] Live data polling every ' + (POLLING_INTERVAL/1000) + 's');
      setInterval(function() { fetchExternalData(); fetchPRData(); }, POLLING_INTERVAL);
    </script>
  </body>
</html>
