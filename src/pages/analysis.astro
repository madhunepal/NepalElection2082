---
export const prerender = false;
import { createClient } from '@supabase/supabase-js';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || process.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || process.env.PUBLIC_SUPABASE_ANON_KEY;

if (!supabaseUrl || !supabaseKey) {
  throw new Error('Missing PUBLIC_SUPABASE_URL or PUBLIC_SUPABASE_ANON_KEY in Vercel environment');
}

const supabase = createClient(supabaseUrl, supabaseKey);

// URL params
const url = new URL(Astro.request.url);
// Prepare Data for Charts (Party Distribution & Qualification)
async function fetchAllChartData() {
  let allData: any[] = [];
  let page = 0;
  const pageSize = 1000;
  while(true) {
    const { data } = await supabase
      .from('candidates')
      .select('party, qualification, province, gender, age')
      .range(page * pageSize, (page + 1) * pageSize - 1);
      
    if (!data || data.length === 0) break;
    allData = allData.concat(data);
    if (data.length < pageSize) break;
    page++;
  }
  return allData;
}

const allCandidatesForCharts = await fetchAllChartData();

// ── Education level aggregation ─────
function classifyEdu(raw: string): string {
  const q = (raw || '').trim().toLowerCase();
  if (!q || q === '-' || q === '0' || q === 'y') return 'Other (अन्य)';
  if (/ph\.?d|\u092a\u093f\.?\u090f\u091a\.?\u0921\u093f|\u092a\u093f\.?\u090f\u091a\.?\u0921\u0940|\u0935\u093f\u0926\u094d\u092f\u093e\u0935\u093e\u0930\u093f\u0927\u093f|\u0935\u093f\u0926\u094d\u092f\u093e\u0935\u093e\u0930\u093f\u0928|\u0935\u093f\u0926\u094d\u092f\u093e \u0935\u093e\u0930\u093f\u0923\u0940|\u0935\u093f\u0926\u094d\u092f\u093e\u0935\u093e\u0930\u093f|\u092c\u093f\u0926\u094d\u092f\u093e\u092c\u093e\u0930\u0940\u0927\u0940|\u092c\u093f\u0926\u094d\u092f\u093e\u0935\u093e\u0930\u0940\u0927\u0940|m\.?phil|\u090f\u092e\.?\u092b\u093f\u0932/i.test(q)) return 'PhD / MPhil';
  if (/master|\u0938\u094d\u0928\u093e\u0924\u0915\u094b\u0924\u094d\u0924\u0930|\u0938\u094d\u200d?\u0928\u093e\u0924\u0915\u094b\u0924\u094d\u0924\u0930|\u0938\u094d\u0928\u093e\u0915\u094b\u0924\u094d\u0924\u0930|\u092e\u093e\u0938\u094d\u091f\u0930|msc|m\.b\.s|m\.ed|m\.ba|m\.sc|m\.a|ma |\u090f\u092e\.?\u090f|\u090f\u092e \u092c\u093f \u090f|\u090f\u092e\.?\u0935\u093f\.?\u090f|mbs|mba|llm|m\.com|\u090f\u092e \u090f/i.test(q)) return 'Masters (स्नातकोत्तर)';
  if (/bachelor|\u0938\u094d\u0928\u093e\u0924\u0915|\u0938\u094d\u200d?\u0928\u093e\u0924\u0915|b\.?a|b\.?sc|b\.?ed|b\.?e\b|b\.?eng|b\.?com|b\.?b|bds|bba|bbs|llb|\u0935\u093f\.\u090f\u0921|\u0935\u093f\.\u090f|\u0935\u093f\.\u090f\u0932|\u0935\u093f\.\u090f\u0938|\u092c\u093f\.?\u090f|\u092c\u093f \u090f\u0938\u0938\u0940|\u090f\u0932\u090f\u0932\u092c\u0940|\u0928\u0930\u094d\u0938\u093f\u0919/i.test(q) && !/\u0938\u094d\u0928\u093e\u0924\u0915\u094b\u0924\u094d\u0924\u0930/i.test(q)) return 'Bachelors (स्नातक)';
  if (/\+2|\+\u0968|10\+2|12 |12\b|\u0661\u0662|i\.?a\b|i\.?sc|i\.?ed|i\.?com|hseb|\u0906\u0908\.?\u090f|\u0906\u0907 \u090f|\u092a\u094d\u0930\u092e\u093e\u0923\u092a\u0924\u094d\u0930|\u092a\u094d\u0930\u092e\u093e\u0923 \u092a\u0924\u094d\u0930|\u092a\u094d\u0930\u0935\u093f\u0923\u0924\u093e|\u092a\u094d\u0930\u0935\u093f\u0923\u0924\u093e|\u092a\u094d\u0930\u0935\u0940\u0923\u0924\u093e|\u092a\u094d\u0930\u0935\u093f\u0923\u093f\u0924\u093e|\u092a\u094d\u0932\u0938 \u091f\u0941|intermediate|diploma|\u0909\u091a\u094d\u091a \u0936\u093f\u0915\u094d\u0937\u093e|certificate|\u0661\u0968 \u092a\u093e\u0938/i.test(q)) return '+2 / Intermediate';
  if (/slc|see|s\.l\.c|\u090f\u0938\.?\u090f\u0932\.?\u0938\u093f|\u090f\u0938\.?\u090f\u0932\.?\u0938\u0940|\u090f\u0938 \u090f\u0932 \u0938\u093f|\u090f\u0938 \u090f\u0932 \u0938\u0940|\u090f\u0938\u090f\u0932\u0938\u0940|\u0915\u0915\u094d\u0937\u093e \u0661\u0960|\u0915\u0915\u094d\u0937\u093e 10|\u092e\u093e\u0927\u094d\u092f\u092e\u093f\u0915|10 pass|\u0661\u0960 \u092a\u093e\u0938|\u0661\u0960$/i.test(q) || q === '10' || q === '\u0661\u0960') return 'SLC / SEE';
  return 'Other (अन्य)';
}

const partyGenderCounts: Record<string, { male: number, female: number, total: number }> = {};
const bachelorsCountByParty: Record<string, number> = {};
const mastersCountByParty: Record<string, number> = {};
const provinceCounts: Record<string, number> = {};
const genderCounts: Record<string, number> = {};
const ageCounts: Record<string, number> = {
  'Below 30': 0,
  '31-35': 0,
  '36-45': 0,
  '46-55': 0,
  '56-65': 0,
  '65 and above': 0
};

if (allCandidatesForCharts) {
  allCandidatesForCharts.forEach(c => {
    // 1. Party
    if (c.party) {
      if (!partyGenderCounts[c.party]) {
        partyGenderCounts[c.party] = { male: 0, female: 0, total: 0 };
      }
      partyGenderCounts[c.party].total += 1;
      if (c.gender === 'पुरुष') partyGenderCounts[c.party].male += 1;
      else if (c.gender === 'महिला') partyGenderCounts[c.party].female += 1;
    }
    
    // 2. Province
    if (c.province) {
      provinceCounts[c.province] = (provinceCounts[c.province] || 0) + 1;
    }

    // 3. Education (Bachelors and Above, Masters and Above)
    const cat = classifyEdu(c.qualification);
    if (c.party) {
      if (cat === 'Bachelors (स्नातक)' || cat === 'Masters (स्नातकोत्तर)' || cat === 'PhD / MPhil') {
        bachelorsCountByParty[c.party] = (bachelorsCountByParty[c.party] || 0) + 1;
      }
      if (cat === 'Masters (स्नातकोत्तर)' || cat === 'PhD / MPhil') {
        mastersCountByParty[c.party] = (mastersCountByParty[c.party] || 0) + 1;
      }
    }

    // 4. Gender
    const g = c.gender || 'अन्य';
    genderCounts[g] = (genderCounts[g] || 0) + 1;

    // 5. Age
    if (c.age) {
      const ageNum = parseInt(c.age, 10);
      if (!isNaN(ageNum)) {
        if (ageNum < 31) ageCounts['Below 30']++;
        else if (ageNum <= 35) ageCounts['31-35']++;
        else if (ageNum <= 45) ageCounts['36-45']++;
        else if (ageNum <= 55) ageCounts['46-55']++;
        else if (ageNum <= 65) ageCounts['56-65']++;
        else ageCounts['65 and above']++;
      }
    }
  });
}

const partyChartData = Object.entries(partyGenderCounts)
  .map(([name, counts]) => ({ name, ...counts }))
  .sort((a, b) => b.total - a.total)
  .slice(0, 10);

const qualChartData = Object.entries(bachelorsCountByParty)
  .map(([name, value]) => ({ name, value }))
  .sort((a, b) => b.value - a.value)
  .slice(0, 10); // Top 10 parties with highest highly educated candidates

const mastersChartData = Object.entries(mastersCountByParty)
  .map(([name, value]) => ({ name, value }))
  .sort((a, b) => b.value - a.value)
  .slice(0, 10); // Top 10 parties with highest highly educated candidates

const provinceChartData = Object.entries(provinceCounts)
  .map(([name, value]) => ({ name: `${name} (${value.toLocaleString()})`, value }))
  .sort((a, b) => b.value - a.value);

const genderChartData = Object.entries(genderCounts)
  .map(([name, value]) => ({ name, value }))
  .sort((a, b) => b.value - a.value);

const ageChartData = Object.entries(ageCounts)
  .map(([name, value]) => ({ name, value }));

let maxAgeGroup = { name: '', value: 0 };
let totalAgeCount = 0;
ageChartData.forEach(g => {
  totalAgeCount += g.value;
  if (g.value > maxAgeGroup.value) {
    maxAgeGroup = g;
  }
});

const maxAgePercentage = totalAgeCount > 0 ? ((maxAgeGroup.value / totalAgeCount) * 100).toFixed(1) : '0.0';
const ageSummary = `Maximum candidates (${maxAgeGroup.value.toLocaleString()}, ${maxAgePercentage}%) are in the age group ${maxAgeGroup.name}.`;
---

<html lang="ne">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>नेपाल निर्वाचन उम्मेदवार ड्यासबोर्ड | Nepal Election Dashboard</title>
    <!-- Chart.js Injection -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>

  <body class="bg-background min-h-screen font-sans antialiased text-foreground">
    
    <!-- Navigation Header -->
    <Header activeTab="analysis" />

    <main class="container mx-auto px-4 py-8">
      
      <div class="mb-8">
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-2 nepali-text text-foreground">
          विश्लेषण (Analysis)
        </h1>
        <p class="text-muted-foreground">
          तथ्याङ्क र चार्टहरू • Visualized Election Data Insights
        </p>
      </div>

      <!-- Analysis Charts Section -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-8 mb-12">
        <!-- Party Chart -->
        <div class="bg-card border border-border rounded-xl p-6 shadow-sm">
          <div class="mb-6">
            <h3 class="font-semibold text-foreground text-lg nepali-text">पार्टी अनुसार उम्मेदवार</h3>
            <p class="text-xs text-muted-foreground">Candidates by Party</p>
          </div>
          <div class="h-80 w-full relative">
            <canvas id="partyChart"></canvas>
          </div>
        </div>

        <!-- Province Chart -->
        <div class="bg-card border border-border rounded-xl p-6 shadow-sm">
          <div class="mb-6">
            <h3 class="font-semibold text-foreground text-lg nepali-text">प्रदेश अनुसार उम्मेदवार</h3>
            <p class="text-xs text-muted-foreground">Candidates by Province</p>
          </div>
          <div class="h-80 w-full relative">
            <canvas id="provinceChart"></canvas>
          </div>
        </div>

        <!-- Qualification Chart (Bachelors) -->
        <div class="bg-card border border-border rounded-xl p-6 shadow-sm">
          <div class="mb-6">
            <h3 class="font-semibold text-foreground text-lg nepali-text">स्नातक वा सो भन्दा माथि</h3>
            <p class="text-xs text-muted-foreground">Bachelors & Above by Party</p>
          </div>
          <div class="h-80 w-full relative">
             <canvas id="qualificationChart"></canvas>
          </div>
        </div>

        <!-- Qualification Chart (Masters) -->
        <div class="bg-card border border-border rounded-xl p-6 shadow-sm">
          <div class="mb-6">
            <h3 class="font-semibold text-foreground text-lg nepali-text">स्नातकोत्तर वा सो भन्दा माथि</h3>
            <p class="text-xs text-muted-foreground">Masters & Above by Party</p>
          </div>
          <div class="h-80 w-full relative">
             <canvas id="mastersChart"></canvas>
          </div>
        </div>

        <!-- Age Chart -->
        <div class="bg-card border border-border rounded-xl p-6 shadow-sm flex flex-col">
          <div class="mb-4">
            <h3 class="font-semibold text-foreground text-lg nepali-text">उमेर समूह</h3>
            <p class="text-xs text-muted-foreground">Age Distribution</p>
          </div>
          <div class="text-sm font-medium text-blue-700 dark:text-blue-300 mb-6 bg-blue-50 dark:bg-blue-900/30 px-4 py-3 rounded-md border border-blue-200 dark:border-blue-800">
            {ageSummary}
          </div>
          <div class="h-[250px] w-full relative flex justify-center items-center">
             <canvas id="ageChart"></canvas>
          </div>
        </div>

        <!-- SagarmathaIQ Link Box -->
        <a href="https://sagarmathaiq.github.io/analytica-nepal.github.io/index.html" target="_blank" rel="noopener noreferrer" class="group relative flex flex-col items-center justify-center bg-[#2b5ba4] hover:bg-[#254f8e] transition-colors rounded-xl p-6 shadow-sm overflow-hidden h-full min-h-[300px] border border-transparent text-center">
          <!-- Mountain Icon (Emoji) -->
          <div class="text-6xl mb-4 group-hover:scale-110 transition-transform duration-300 drop-shadow-md">🏔️</div>
          
          <!-- Brand Name -->
          <h2 class="text-white text-2xl md:text-3xl font-bold mb-2 tracking-tight">
            Nepal 2082 Election Forecasts
          </h2>
          
          <!-- Tagline -->
          <p class="text-white/90 text-sm md:text-base font-medium">
            by Sagarmatha Analytics
          </p>

          <!-- Headline overlay effect -->
          <div class="absolute inset-0 border-2 border-white/10 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
          
          <!-- Corner indicator -->
          <div class="absolute top-4 right-4 text-white/50 group-hover:text-white/80 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
          </div>
        </a>
      </div>
    </main>

    <Footer />
    <script is:inline define:vars={{ partyChartData, qualChartData, mastersChartData, provinceChartData, genderChartData, ageChartData }}>
      // -----------------------------
      // Chart.js Configuration
      document.addEventListener("DOMContentLoaded", function() {
        const CHART_COLORS = [
          "hsl(215, 55%, 35%)", // Deep blue
          "hsl(350, 55%, 50%)", // Crimson
          "hsl(160, 50%, 45%)", // Green
          "hsl(35, 70%, 55%)",  // Orange/Yellow
          "hsl(270, 40%, 55%)", // Purple
          "hsl(190, 55%, 45%)", // Cyan
          "hsl(25, 65%, 50%)",  // Orange
          "hsl(200, 15%, 50%)", // Gray blue
        ];

        function getTextColor() { return document.documentElement.classList.contains('dark') ? '#e2e8f0' : '#475569'; }
        function getGridColor() { return document.documentElement.classList.contains('dark') ? '#334155' : '#f1f5f9'; }
        function getBorderColor() { return document.documentElement.classList.contains('dark') ? '#1e293b' : '#fff'; }
        
        var charts = [];

        // 1. Party Bar Chart (Horizontal)
        const ctxParty = document.getElementById('partyChart');
        if (ctxParty && partyChartData.length > 0) {
          
          // Helper to abbreviate long party names exactly like their getShortPartyName()
          const getShortName = (name) => {
            const map = {
              "नेपाल कम्युनिष्ट पार्टी (एकीकृत मार्क्सवादी लेनिनवादी)": "नेकपा एमाले",
              "नेपाली काँग्रेस": "काँग्रेस",
              "नेपाल कम्युनिष्ट पार्टी (माओवादी केन्द्र)": "माओवादी केन्द्र",
              "राष्ट्रिय स्वतन्त्र पार्टी": "रास्वपा",
              "राष्ट्रिय प्रजातन्त्र पार्टी": "राप्रपा",
              "जनता समाजवादी पार्टी, नेपाल": "जसपा"
            };
            return map[name] || (name.length > 20 ? name.substring(0, 20) + '...' : name);
          };

          const labels = partyChartData.map(d => getShortName(d.name));
          const data = partyChartData.map(d => d.value);
          const fullNames = partyChartData.map(d => d.name);

          const partyChart = new Chart(ctxParty, {
            type: 'bar',
            data: {
              labels: labels,
              datasets: [
                {
                  label: 'Male (पुरुष)',
                  data: partyChartData.map(d => d.male),
                  backgroundColor: '#3b82f6',
                  borderWidth: 0,
                },
                {
                  label: 'Female (महिला)',
                  data: partyChartData.map(d => d.female),
                  backgroundColor: '#ec4899',
                  borderWidth: 0,
                  borderRadius: { topRight: 4, bottomRight: 4 }
                }
              ]
            },
            options: {
              indexAxis: 'y', // Horizontal
              maintainAspectRatio: false,
              plugins: {
                legend: { position: 'top', labels: { color: getTextColor(), font: { size: 11 } } },
                tooltip: {
                  backgroundColor: 'rgba(255, 255, 255, 0.95)',
                  titleColor: '#000',
                  bodyColor: '#333',
                  borderColor: '#e2e8f0',
                  borderWidth: 1,
                  padding: 10,
                  callbacks: {
                    title: (ctx) => `${fullNames[ctx[0].dataIndex]}`,
                    label: (ctx) => ` ${ctx.dataset.label}: ${ctx.raw.toLocaleString()}`
                  }
                }
              },
              scales: {
                x: {
                  stacked: true,
                  grid: { color: getGridColor(), drawBorder: false },
                  ticks: { font: { size: 12 }, color: getTextColor() }
                },
                y: {
                  stacked: true,
                  grid: { display: false },
                  ticks: { font: { size: 11, family: 'Noto Sans Devanagari' }, color: getTextColor() }
                }
              }
            }
          });
          charts.push(partyChart);
        }

        // 2. Qualification Bar Chart (Bachelors and Above)
        const ctxQual = document.getElementById('qualificationChart');
        if (ctxQual && qualChartData.length > 0) {
          
          const getShortName = (name) => {
            const map = {
              "नेपाल कम्युनिष्ट पार्टी (एकीकृत मार्क्सवादी लेनिनवादी)": "नेकपा एमाले",
              "नेपाली काँग्रेस": "काँग्रेस",
              "नेपाल कम्युनिष्ट पार्टी (माओवादी केन्द्र)": "माओवादी केन्द्र",
              "राष्ट्रिय स्वतन्त्र पार्टी": "रास्वपा",
              "राष्ट्रिय प्रजातन्त्र पार्टी": "राप्रपा",
              "जनता समाजवादी पार्टी, नेपाल": "जसपा"
            };
            return map[name] || (name.length > 20 ? name.substring(0, 20) + '...' : name);
          };

          const labels = qualChartData.map(d => getShortName(d.name));
          const data = qualChartData.map(d => d.value);
          const fullNames = qualChartData.map(d => d.name);

          const qualChart = new Chart(ctxQual, {
            type: 'bar',
            data: {
              labels: labels,
              datasets: [{
                data: data,
                backgroundColor: CHART_COLORS,
                borderWidth: 0,
                borderRadius: 4,
                barPercentage: 0.6
              }]
            },
            options: {
              indexAxis: 'y', // Horizontal
              maintainAspectRatio: false,
              plugins: {
                legend: { display: false },
                tooltip: {
                  backgroundColor: 'rgba(255, 255, 255, 0.95)',
                  titleColor: '#000',
                  bodyColor: '#333',
                  borderColor: '#e2e8f0',
                  borderWidth: 1,
                  padding: 10,
                  callbacks: {
                    title: (ctx) => `${ctx[0].raw.toLocaleString()} उम्मेदवार`,
                    label: (ctx) => fullNames[ctx.dataIndex]
                  }
                }
              },
              scales: {
                x: {
                  grid: { color: getGridColor(), drawBorder: false },
                  ticks: { font: { size: 12 }, color: getTextColor() }
                },
                y: {
                  grid: { display: false },
                  ticks: { font: { size: 11, family: 'Noto Sans Devanagari' }, color: getTextColor() }
                }
              }
            }
          });
          charts.push(qualChart);
        }

        // 2b. Masters and Above Bar Chart
        const ctxMasters = document.getElementById('mastersChart');
        if (ctxMasters && mastersChartData.length > 0) {
          
          const getShortName = (name) => {
            const map = {
              "नेपाल कम्युनिष्ट पार्टी (एकीकृत मार्क्सवादी लेनिनवादी)": "नेकपा एमाले",
              "नेपाली काँग्रेस": "काँग्रेस",
              "नेपाल कम्युनिष्ट पार्टी (माओवादी केन्द्र)": "माओवादी केन्द्र",
              "राष्ट्रिय स्वतन्त्र पार्टी": "रास्वपा",
              "राष्ट्रिय प्रजातन्त्र पार्टी": "राप्रपा",
              "जनता समाजवादी पार्टी, नेपाल": "जसपा"
            };
            return map[name] || (name.length > 20 ? name.substring(0, 20) + '...' : name);
          };

          const labels = mastersChartData.map(d => getShortName(d.name));
          const data = mastersChartData.map(d => d.value);
          const fullNames = mastersChartData.map(d => d.name);

          const mastersChart = new Chart(ctxMasters, {
            type: 'bar',
            data: {
              labels: labels,
              datasets: [{
                data: data,
                backgroundColor: CHART_COLORS,
                borderWidth: 0,
                borderRadius: 4,
                barPercentage: 0.6
              }]
            },
            options: {
              indexAxis: 'y', // Horizontal
              maintainAspectRatio: false,
              plugins: {
                legend: { display: false },
                tooltip: {
                  backgroundColor: 'rgba(255, 255, 255, 0.95)',
                  titleColor: '#000',
                  bodyColor: '#333',
                  borderColor: '#e2e8f0',
                  borderWidth: 1,
                  padding: 10,
                  callbacks: {
                    title: (ctx) => `${ctx[0].raw.toLocaleString()} उम्मेदवार`,
                    label: (ctx) => fullNames[ctx.dataIndex]
                  }
                }
              },
              scales: {
                x: {
                  grid: { color: getGridColor(), drawBorder: false },
                  ticks: { font: { size: 12 }, color: getTextColor() }
                },
                y: {
                  grid: { display: false },
                  ticks: { font: { size: 11, family: 'Noto Sans Devanagari' }, color: getTextColor() }
                }
              }
            }
          });
          charts.push(mastersChart);
        }

        // 3. Age Pie Chart (Doughnut style)
        const ctxAge = document.getElementById('ageChart');
        if (ctxAge && ageChartData.length > 0) {
          const labels = ageChartData.map(d => d.name);
          const data = ageChartData.map(d => d.value);

          const ageChart = new Chart(ctxAge, {
            type: 'doughnut',
            data: {
              labels: labels,
              datasets: [{
                data: data,
                backgroundColor: CHART_COLORS,
                borderWidth: 2,
                borderColor: getBorderColor()
              }]
            },
            options: {
              maintainAspectRatio: false,
              cutout: '60%',
              plugins: {
                legend: {
                  position: 'right',
                  labels: {
                    color: getTextColor(),
                    pointStyle: 'circle',
                    usePointStyle: true,
                    boxWidth: 8,
                    font: { size: 11 }
                  }
                },
                tooltip: {
                  backgroundColor: 'rgba(255, 255, 255, 0.95)',
                  titleColor: '#000',
                  bodyColor: '#333',
                  borderColor: '#e2e8f0',
                  borderWidth: 1,
                  padding: 10,
                  callbacks: {
                    label: (ctx) => {
                      const value = ctx.raw;
                      const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                      const percentage = ((value / total) * 100).toFixed(1);
                      return ` ${value.toLocaleString()} (${percentage}%)`;
                    }
                  }
                }
              }
            }
          });
          charts.push(ageChart);
        }
        // 4. Province Bar Chart (Horizontal)
        const ctxProvince = document.getElementById('provinceChart');
        if (ctxProvince && provinceChartData.length > 0) {
          const labels = provinceChartData.map(d => d.name);
          const data = provinceChartData.map(d => d.value);

          const provinceChart = new Chart(ctxProvince, {
            type: 'bar',
            data: {
              labels: labels,
              datasets: [{
                data: data,
                backgroundColor: CHART_COLORS,
                borderWidth: 0,
                borderRadius: 4,
                barPercentage: 0.6
              }]
            },
            options: {
              indexAxis: 'y', // Horizontal
              maintainAspectRatio: false,
              plugins: {
                legend: { display: false },
                tooltip: {
                  backgroundColor: 'rgba(255, 255, 255, 0.95)',
                  titleColor: '#000',
                  bodyColor: '#333',
                  borderColor: '#e2e8f0',
                  borderWidth: 1,
                  padding: 10,
                  callbacks: {
                    title: (ctx) => `${ctx[0].raw.toLocaleString()} उम्मेदवार`
                  }
                }
              },
              scales: {
                x: {
                  grid: { color: getGridColor(), drawBorder: false },
                  ticks: { font: { size: 12 }, color: getTextColor() }
                },
                y: {
                  grid: { display: false },
                  ticks: { font: { size: 11, family: 'Noto Sans Devanagari' }, color: getTextColor() }
                }
              }
            }
          });
          charts.push(provinceChart);
        }

        // Apply dark mode overrides dynamically
        function updateChartThemes() {
          var tColor = getTextColor();
          var gColor = getGridColor();
          var bColor = getBorderColor();
          charts.forEach(function(c) {
            if (c.config.type === 'doughnut') {
              c.options.plugins.legend.labels.color = tColor;
              c.data.datasets[0].borderColor = bColor;
            } else if (c.config.type === 'bar') {
              if (c.options.plugins.legend && c.options.plugins.legend.labels) {
                c.options.plugins.legend.labels.color = tColor;
              }
              c.options.scales.x.ticks.color = tColor;
              c.options.scales.x.grid.color = gColor;
              c.options.scales.y.ticks.color = tColor;
            }
            c.update();
          });
        }

        // Listen for class changes on HTML tag
        var observer = new MutationObserver(function(mutations) {
          mutations.forEach(function(m) {
            if (m.attributeName === 'class') updateChartThemes();
          });
        });
        observer.observe(document.documentElement, { attributes: true });
      });
    </script>
  </body>
</html>