<html lang="ne">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>निर्वाचन ड्यासबोर्ड | Nepal Election 2082</title>
    <meta name="description" content="Nepal Election 2082 Dashboard — Explore 3,400+ candidates by education, gender, party, and constituency. Real-time data from Election Commission of Nepal." />

    <!-- Open Graph (Facebook, LinkedIn, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="निर्वाचन ड्यासबोर्ड | Nepal Election 2082" />
    <meta property="og:description" content="Explore 3,400+ candidates by education, gender, party & constituency. Nepal House of Representatives Election 2082." />
    <meta property="og:image" content="https://nepalelection.info/og-image-3406.png" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1008" />
    <meta property="og:url" content="https://nepalelection.info/" />
    <meta property="og:site_name" content="Nepal Election 2082" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="निर्वाचन ड्यासबोर्ड | Nepal Election 2082" />
    <meta name="twitter:description" content="Explore 3,400+ candidates by education, gender, party & constituency." />
    <meta name="twitter:image" content="https://nepalelection.info/og-image-3406.png" />

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>

  <body class="bg-background min-h-screen font-sans antialiased text-foreground">
    <Header activeTab="dashboard" />

    <main class="container mx-auto px-4 py-8">

      <!-- Title -->
      <div class="mb-8">
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-1">
          निर्वाचन ड्यासबोर्ड
          <span class="text-lg font-normal text-muted-foreground ml-1">(Election Dashboard)</span>
        </h1>
        <p class="text-muted-foreground text-sm">नेपाल प्रतिनिधि सभा निर्वाचन २०८२ • Nepal House of Representatives Election 2082</p>
      </div>

      <!-- ══════════ ROW 1: Stats Cards ══════════ -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">

        <!-- Voters -->
        <div class="bg-card border border-border rounded-xl p-5 shadow-sm flex justify-between items-start">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-semibold text-muted-foreground uppercase tracking-wide">Voters</span>
            </div>
            <p class="text-3xl font-bold text-foreground">18.9M</p>
            <p class="text-xs text-muted-foreground mt-1">कुल मतदाता</p>
          </div>
          <div class="bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 p-3 rounded-xl text-blue-600 dark:text-blue-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
        </div>

        <!-- Candidates (clickable → /candidates) -->
        <a href="/candidates" class="bg-card border border-border rounded-xl p-5 shadow-sm flex justify-between items-start hover:shadow-md hover:border-green-300 transition-all group">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-semibold text-muted-foreground uppercase tracking-wide">Candidates</span>
            </div>
            <p class="text-3xl font-bold text-foreground group-hover:text-green-600 transition-colors">{totalCandidates.toLocaleString()}</p>
            <p class="text-xs text-muted-foreground mt-1">कुल उम्मेदवार • <span class="text-green-600 group-hover:underline">View all →</span></p>
          </div>
          <div class="bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 p-3 rounded-xl text-green-600 dark:text-green-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          </div>
        </a>

        <!-- Seats (clickable → /result) -->
        <a href="/result" class="bg-card border border-border rounded-xl p-5 shadow-sm flex justify-between items-start hover:shadow-md hover:border-purple-300 transition-all group">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-semibold text-muted-foreground uppercase tracking-wide">Seats</span>
            </div>
            <p class="text-3xl font-bold text-foreground group-hover:text-purple-600 transition-colors">275</p>
            <p class="text-xs text-muted-foreground mt-1">प्रतिनिधि सभा सीट • <span class="text-purple-600 group-hover:underline">View results →</span></p>
          </div>
          <div class="bg-purple-50 dark:bg-purple-900/30 border border-purple-200 dark:border-purple-800 p-3 rounded-xl text-purple-600 dark:text-purple-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          </div>
        </a>

        <!-- Parties -->
        <div class="bg-card border border-border rounded-xl p-5 shadow-sm flex justify-between items-start">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-semibold text-muted-foreground uppercase tracking-wide">Parties</span>
            </div>
            <p class="text-3xl font-bold text-foreground">{totalParties}</p>
            <p class="text-xs text-muted-foreground mt-1">राजनीतिक दलहरू</p>
          </div>
          <div class="bg-amber-50 dark:bg-amber-900/30 border border-amber-200 dark:border-amber-800 p-3 rounded-xl text-amber-600 dark:text-amber-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>
          </div>
        </div>
      </div>

      <!-- ══════════ ROW 2: Charts ══════════ -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-8">

        <!-- Education Pie Chart -->
        <div class="bg-card border border-border rounded-xl p-5 shadow-sm">
          <h3 class="font-semibold text-foreground text-base mb-1">📚 Education Level</h3>
          <p class="text-xs text-muted-foreground mb-4">शैक्षिक योग्यता अनुसार</p>
          <div class="h-64 relative">
            <canvas id="eduChart"></canvas>
          </div>
        </div>

        <!-- Gender Pie Chart -->
        <div class="bg-card border border-border rounded-xl p-5 shadow-sm">
          <h3 class="font-semibold text-foreground text-base mb-1">👤 Gender Distribution</h3>
          <p class="text-xs text-muted-foreground mb-4">लिङ्ग अनुसार</p>
          <div class="h-64 relative">
            <canvas id="genderChart"></canvas>
          </div>
        </div>

        <!-- Parties Bar Chart -->
        <div class="bg-card border border-border rounded-xl p-5 shadow-sm">
          <h3 class="font-semibold text-foreground text-base mb-1">🏛️ Top Parties</h3>
          <p class="text-xs text-muted-foreground mb-4">पार्टी अनुसार उम्मेदवार</p>
          <div class="h-64 relative">
            <canvas id="partyChart"></canvas>
          </div>
        </div>
      </div>

      <!-- ══════════ ROW 3: Featured Constituencies ══════════ -->
      <div class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-bold text-foreground">🗳️ Featured Constituencies</h2>
          <a href="/candidates" class="text-blue-600 text-sm font-medium hover:underline">View all candidates →</a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {featuredMatchups.map(matchup => (
            <div class="bg-card border border-border rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow">
              <!-- Location + tag -->
              <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-2">
                  <span class="text-blue-600 dark:text-blue-400">📍</span>
                  <span class="font-semibold text-sm text-foreground">{matchup.label}</span>
                </div>
                <span class="text-xs px-2 py-0.5 rounded-full bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-800 font-medium">
                  {matchup.tag}
                </span>
              </div>

              <!-- VS card -->
              <div class="flex items-center justify-between gap-2">
                {matchup.candidates.map((c, i) => {
                  const photoUrl = c.id
                    ? `https://election.gov.np/2082/uploads/images/candidates/${c.id}.jpg`
                    : null;
                  return (
                    <div class="flex-1 text-center">
                      <!-- Photo -->
                      <div class="relative h-16 w-16 mx-auto rounded-full bg-slate-100 dark:bg-slate-800 overflow-hidden border-2 border-slate-200 dark:border-slate-700 mb-2">
                        <div class="absolute inset-0 flex items-center justify-center text-slate-400 dark:text-slate-500 font-bold text-lg">
                          {c.name.charAt(0)}
                        </div>
                        {photoUrl && (
                          <img
                            src={photoUrl}
                            alt={c.name}
                            class="featured-photo absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300"
                            loading="lazy"
                          />
                        )}
                      </div>
                      <p class="text-xs font-semibold text-foreground leading-tight">{c.short}</p>
                    </div>
                  );
                })}
              </div>

              <!-- VS divider was implicit -->
              <div class="text-center my-1">
                <span class="text-xs font-bold text-muted-foreground bg-secondary px-3 py-0.5 rounded-full">VS</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- ══════════ CTA: See All Candidates ══════════ -->
      <div class="text-center py-8 bg-gradient-to-r from-blue-50 to-purple-50 dark:from-blue-900/20 dark:to-purple-900/20 border border-blue-200 dark:border-blue-900/50 rounded-2xl mb-8">
        <h3 class="text-xl font-bold text-foreground mb-2">सबै उम्मेदवारहरू हेर्नुहोस्</h3>
        <p class="text-muted-foreground text-sm mb-4">Browse all {totalCandidates.toLocaleString()} candidates with advanced filters</p>
        <a href="/candidates" class="inline-block px-8 py-3 bg-blue-600 hover:bg-blue-700 dark:bg-blue-700 dark:hover:bg-blue-800 text-white font-semibold rounded-lg shadow-md transition-colors text-sm">
          View All Candidates →
        </a>
      </div>

    </main>

    <Footer />

    <script is:inline define:vars={{ eduData, genderData, partyChartData, totalCandidates }}>
      document.addEventListener('DOMContentLoaded', function() {
        var COLORS = [
          '#3b82f6','#ef4444','#22c55e','#f59e0b','#8b5cf6',
          '#06b6d4','#f97316','#64748b','#ec4899','#14b8a6'
        ];
        
        // Theme aware text color helper
        function getTextColor() {
          return document.documentElement.classList.contains('dark') ? '#e2e8f0' : '#475569';
        }
        function getGridColor() {
          return document.documentElement.classList.contains('dark') ? '#334155' : '#f1f5f9';
        }
        function getBorderColor() {
          return document.documentElement.classList.contains('dark') ? '#1e293b' : '#fff';
        }

        var charts = [];

        // ── Education Doughnut ──
        var eduCtx = document.getElementById('eduChart');
        if (eduCtx) {
          new Chart(eduCtx, {
            type: 'doughnut',
            data: {
              labels: eduData.map(function(d){return d.name;}),
              datasets: [{
                data: eduData.map(function(d){return d.value;}),
                backgroundColor: COLORS,
                borderColor: '#fff', borderWidth: 2
              }]
            },
            options: {
              responsive: true, maintainAspectRatio: false, cutout: '55%',
              plugins: {
                legend: { position: 'right', labels: { color: getTextColor(), boxWidth: 10, font: { size: 10 }, padding: 8, usePointStyle: true, pointStyle: 'circle' } },
                tooltip: {
                  callbacks: {
                    label: function(ctx) {
                      var total = ctx.dataset.data.reduce(function(a,b){return a+b;},0);
                      return ' ' + ctx.raw.toLocaleString() + ' (' + ((ctx.raw/total)*100).toFixed(1) + '%)';
                    }
                  }
                }
              }
            }
          });
          charts.push(eduChart);
        }

        // ── Gender Doughnut ──
        var genderCtx = document.getElementById('genderChart');
        if (genderCtx) {
          var gColors = ['#3b82f6', '#ec4899', '#94a3b8'];
          new Chart(genderCtx, {
            type: 'doughnut',
            data: {
              labels: genderData.map(function(d){return d.name;}),
              datasets: [{
                data: genderData.map(function(d){return d.value;}),
                backgroundColor: gColors,
                borderColor: '#fff', borderWidth: 2
              }]
            },
            options: {
              responsive: true, maintainAspectRatio: false, cutout: '55%',
              plugins: {
                legend: { position: 'right', labels: { color: getTextColor(), boxWidth: 10, font: { size: 11 }, padding: 10, usePointStyle: true, pointStyle: 'circle' } },
                tooltip: {
                  callbacks: {
                    label: function(ctx) {
                      var total = ctx.dataset.data.reduce(function(a,b){return a+b;},0);
                      return ' ' + ctx.raw.toLocaleString() + ' (' + ((ctx.raw/total)*100).toFixed(1) + '%)';
                    }
                  }
                }
              }
            }
          });
          charts.push(genderChart);
        }

        // ── Party Horizontal Bar ──
        var partyCtx = document.getElementById('partyChart');
        if (partyCtx) {
          var shortNames = {
            "\u0928\u0947\u092a\u093e\u0932\u0940 \u0915\u093e\u0901\u0917\u094d\u0930\u0947\u0938": "\u0915\u093e\u0901\u0917\u094d\u0930\u0947\u0938",
            "\u0928\u0947\u092a\u093e\u0932 \u0915\u092e\u094d\u092f\u0941\u0928\u093f\u0937\u094d\u091f \u092a\u093e\u0930\u094d\u091f\u0940 (\u090f\u0915\u0940\u0915\u0943\u0924 \u092e\u093e\u0930\u094d\u0915\u094d\u0938\u0935\u093e\u0926\u0940 \u0932\u0947\u0928\u093f\u0928\u0935\u093e\u0926\u0940)": "\u090f\u092e\u093e\u0932\u0947",
            "\u0928\u0947\u092a\u093e\u0932 \u0915\u092e\u094d\u092f\u0941\u0928\u093f\u0937\u094d\u091f \u092a\u093e\u0930\u094d\u091f\u0940 (\u092e\u093e\u0913\u0935\u093e\u0926\u0940 \u0915\u0947\u0928\u094d\u0926\u094d\u0930)": "\u092e\u093e\u0913\u0935\u093e\u0926\u0940",
            "\u0930\u093e\u0937\u094d\u091f\u094d\u0930\u093f\u092f \u0938\u094d\u0935\u0924\u0928\u094d\u0924\u094d\u0930 \u092a\u093e\u0930\u094d\u091f\u0940": "\u0930\u093e.\u0938\u094d\u0935.\u092a\u093e.",
            "\u0930\u093e\u0937\u094d\u091f\u094d\u0930\u093f\u092f \u092a\u094d\u0930\u091c\u093e\u0924\u0928\u094d\u0924\u094d\u0930 \u092a\u093e\u0930\u094d\u091f\u0940": "\u0930\u093e\u092a\u094d\u0930\u092a\u093e",
            "\u091c\u0928\u0924\u093e \u0938\u092e\u093e\u091c\u0935\u093e\u0926\u0940 \u092a\u093e\u0930\u094d\u091f\u0940, \u0928\u0947\u092a\u093e\u0932": "\u091c\u0938\u092a\u093e",
            "\u0938\u094d\u0935\u0924\u0928\u094d\u0924\u094d\u0930": "\u0938\u094d\u0935\u0924\u0928\u094d\u0924\u094d\u0930",
            "\u0905\u0928\u094d\u092f (\u004f\u0074\u0068\u0065\u0072\u0073)": "\u0905\u0928\u094d\u092f",
          };
          var labels = partyChartData.map(function(d) { return shortNames[d.name] || (d.name.length > 16 ? d.name.substring(0,14)+'…' : d.name); });

          new Chart(partyCtx, {
            type: 'bar',
            data: {
              labels: labels,
              datasets: [{
                data: partyChartData.map(function(d){return d.value;}),
                backgroundColor: COLORS,
                borderWidth: 0, borderRadius: 4, barPercentage: 0.65
              }]
            },
            options: {
              indexAxis: 'y', responsive: true, maintainAspectRatio: false,
              plugins: {
                legend: { display: false },
                tooltip: {
                  callbacks: { title: function(ctx) { return partyChartData[ctx[0].dataIndex].name; } }
                }
              },
              scales: {
                x: { grid: { color: getGridColor() }, ticks: { color: getTextColor(), font: { size: 10 } } },
                y: { grid: { display: false }, ticks: { color: getTextColor(), font: { size: 10 } } }
              }
            }
          });
          charts.push(partyChart);
        }

        // Apply dark mode overrides dynamically
        function updateChartThemes() {
          var tColor = getTextColor();
          var gColor = getGridColor();
          var bColor = getBorderColor();
          charts.forEach(function(c) {
            if (c.config.type === 'doughnut') {
              c.options.plugins.legend.labels.color = tColor;
              c.data.datasets[0].borderColor = bColor;
            } else if (c.config.type === 'bar') {
              c.options.scales.x.ticks.color = tColor;
              c.options.scales.x.grid.color = gColor;
              c.options.scales.y.ticks.color = tColor;
            }
            c.update();
          });
        }

        // Listen for class changes on HTML tag
        var observer = new MutationObserver(function(mutations) {
          mutations.forEach(function(m) {
            if (m.attributeName === 'class') updateChartThemes();
          });
        });
        observer.observe(document.documentElement, { attributes: true });

        // Photo lazy-load for featured candidates
        document.querySelectorAll('.featured-photo').forEach(function(img) {
          img.addEventListener('load', function() { img.classList.remove('opacity-0'); });
          img.addEventListener('error', function() { img.remove(); });
        });
      });
    </script>
  </body>
</html>