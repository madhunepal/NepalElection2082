---
export const prerender = false;
import { createClient } from '@supabase/supabase-js';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || process.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || process.env.PUBLIC_SUPABASE_ANON_KEY;
if (!supabaseUrl || !supabaseKey) throw new Error('Missing Supabase credentials');
const supabase = createClient(supabaseUrl, supabaseKey);

// ── Fetch all data in parallel ──────────────────────────────
async function fetchAll() {
  let all: any[] = []; let p = 0;
  while (true) {
    const { data } = await supabase.from('candidates')
      .select('candidate_id,name,party,gender,qualification,district,constituency,province')
      .range(p*1000,(p+1)*1000-1);
    if (!data || !data.length) break;
    all = all.concat(data);
    if (data.length < 1000) break; p++;
  }
  return all;
}

const allCandidates = await fetchAll();
const totalCandidates = 3406;

// Count unique parties
const uniqueParties = [...new Set(allCandidates.map(c => c.party).filter(Boolean))];
const totalParties = uniqueParties.length;

// ── Education level aggregation (user-defined 6 buckets) ─────
function classifyEdu(raw: string): string {
  const q = (raw || '').trim().toLowerCase();
  if (!q || q === '-' || q === '0' || q === 'y') return 'Other (अन्य)';

  // PhD / MPhil
  if (/ph\.?d|\u092a\u093f\.?\u090f\u091a\.?\u0921\u093f|\u092a\u093f\.?\u090f\u091a\.?\u0921\u0940|\u0935\u093f\u0926\u094d\u092f\u093e\u0935\u093e\u0930\u093f\u0927\u093f|\u0935\u093f\u0926\u094d\u092f\u093e\u0935\u093e\u0930\u093f\u0928|\u0935\u093f\u0926\u094d\u092f\u093e \u0935\u093e\u0930\u093f\u0923\u0940|\u0935\u093f\u0926\u094d\u092f\u093e\u0935\u093e\u0930\u093f|\u092c\u093f\u0926\u094d\u092f\u093e\u092c\u093e\u0930\u0940\u0927\u0940|\u092c\u093f\u0926\u094d\u092f\u093e\u0935\u093e\u0930\u0940\u0927\u0940|m\.?phil|\u090f\u092e\.?\u092b\u093f\u0932/i.test(q)) return 'PhD / MPhil';

  // Masters
  if (/master|\u0938\u094d\u0928\u093e\u0924\u0915\u094b\u0924\u094d\u0924\u0930|\u0938\u094d\u200d?\u0928\u093e\u0924\u0915\u094b\u0924\u094d\u0924\u0930|\u0938\u094d\u0928\u093e\u0915\u094b\u0924\u094d\u0924\u0930|\u092e\u093e\u0938\u094d\u091f\u0930|msc|m\.b\.s|m\.ed|m\.ba|m\.sc|m\.a|ma |\u090f\u092e\.?\u090f|\u090f\u092e \u092c\u093f \u090f|\u090f\u092e\.?\u0935\u093f\.?\u090f|mbs|mba|llm|m\.com|\u090f\u092e \u090f/i.test(q)) return 'Masters (स्नातकोत्तर)';

  // Bachelors
  if (/bachelor|\u0938\u094d\u0928\u093e\u0924\u0915|\u0938\u094d\u200d?\u0928\u093e\u0924\u0915|b\.?a|b\.?sc|b\.?ed|b\.?e\b|b\.?eng|b\.?com|b\.?b|bds|bba|bbs|llb|\u0935\u093f\.\u090f\u0921|\u0935\u093f\.\u090f|\u0935\u093f\.\u090f\u0932|\u0935\u093f\.\u090f\u0938|\u092c\u093f\.?\u090f|\u092c\u093f \u090f\u0938\u0938\u0940|\u090f\u0932\u090f\u0932\u092c\u0940|\u0928\u0930\u094d\u0938\u093f\u0919/i.test(q) && !/\u0938\u094d\u0928\u093e\u0924\u0915\u094b\u0924\u094d\u0924\u0930/i.test(q)) return 'Bachelors (स्नातक)';

  // +2 / Intermediate
  if (/\+2|\+\u0968|10\+2|12 |12\b|\u0661\u0662|i\.?a\b|i\.?sc|i\.?ed|i\.?com|hseb|\u0906\u0908\.?\u090f|\u0906\u0907 \u090f|\u092a\u094d\u0930\u092e\u093e\u0923\u092a\u0924\u094d\u0930|\u092a\u094d\u0930\u092e\u093e\u0923 \u092a\u0924\u094d\u0930|\u092a\u094d\u0930\u0935\u093f\u0923\u0924\u093e|\u092a\u094d\u0930\u0935\u093f\u0923\u0924\u093e|\u092a\u094d\u0930\u0935\u0940\u0923\u0924\u093e|\u092a\u094d\u0930\u0935\u093f\u0923\u093f\u0924\u093e|\u092a\u094d\u0932\u0938 \u091f\u0941|intermediate|diploma|\u0909\u091a\u094d\u091a \u0936\u093f\u0915\u094d\u0937\u093e|certificate|\u0661\u0968 \u092a\u093e\u0938/i.test(q)) return '+2 / Intermediate';

  // SLC / SEE
  if (/slc|see|s\.l\.c|\u090f\u0938\.?\u090f\u0932\.?\u0938\u093f|\u090f\u0938\.?\u090f\u0932\.?\u0938\u0940|\u090f\u0938 \u090f\u0932 \u0938\u093f|\u090f\u0938 \u090f\u0932 \u0938\u0940|\u090f\u0938\u090f\u0932\u0938\u0940|\u0915\u0915\u094d\u0937\u093e \u0661\u0960|\u0915\u0915\u094d\u0937\u093e 10|\u092e\u093e\u0927\u094d\u092f\u092e\u093f\u0915|10 pass|\u0661\u0960 \u092a\u093e\u0938|\u0661\u0960$/i.test(q) || q === '10' || q === '\u0661\u0960') return 'SLC / SEE';

  return 'Other (अन्य)';
}

const eduMap: Record<string, number> = {};
allCandidates.forEach(c => {
  const cat = classifyEdu(c.qualification);
  eduMap[cat] = (eduMap[cat] || 0) + 1;
});
// Fixed order for the pie chart
const eduOrder = ['PhD / MPhil', 'Masters (स्नातकोत्तर)', 'Bachelors (स्नातक)', '+2 / Intermediate', 'SLC / SEE', 'Other (अन्य)'];
const eduData = eduOrder.filter(k => eduMap[k]).map(k => ({ name: k, value: eduMap[k] }));

// ── Gender aggregation ──────────────────────────────────────
const genderMap: Record<string, number> = {};
allCandidates.forEach(c => {
  const g = c.gender || 'अन्य';
  genderMap[g] = (genderMap[g] || 0) + 1;
});
const genderData = Object.entries(genderMap)
  .map(([name, value]) => ({ name, value }))
  .sort((a, b) => b.value - a.value);

// ── Party aggregation (top 7 + others) ──────────────────────
const partyMap: Record<string, number> = {};
allCandidates.forEach(c => {
  if (c.party) partyMap[c.party] = (partyMap[c.party] || 0) + 1;
});
const sortedParties = Object.entries(partyMap)
  .map(([name, value]) => ({ name, value }))
  .sort((a, b) => b.value - a.value);
const top7 = sortedParties.slice(0, 7);
const othersCount = sortedParties.slice(7).reduce((s, p) => s + p.value, 0);
const partyChartData = [...top7, { name: 'अन्य (Others)', value: othersCount }];

// ── Short party name helper ─────────────────────────────────
function shortParty(p: string) {
  if (p.includes('एकीकृत मार्क्सवादी')) return 'नेकपा एमाले';
  if (p.includes('माओवादी')) return 'माओवादी केन्द्र';
  if (p.includes('काँग्रेस')) return 'नेपाली काँग्रेस';
  if (p.includes('स्वतन्त्र पार्टी')) return 'रा.स्व.पा.';
  if (p.includes('प्रजातन्त्र पार्टी')) return 'राप्रपा';
  if (p.includes('जनता समाजवादी')) return 'जसपा';
  if (p.includes('लोकतान्त्रिक समाजवादी')) return 'लो.स.पा.';
  if (p.includes('जनमोर्चा')) return 'जनमोर्चा';
  if (p === 'स्वतन्त्र') return 'स्वतन्त्र';
  return p.length > 18 ? p.slice(0, 16) + '…' : p;
}

// ── Featured Constituencies ─────────────────────────────────
// Hard-coded matchups as requested by user
const featuredMatchups = [
  {
    label: 'झापा - क्षेत्र 5',
    tag: '🔥 Hot Seat',
    candidates: [
      { id: 339653, name: 'वालेन्द्र शाह (बालेन)', short: 'बालेन' },
      { id: 340111, name: 'के.पी शर्मा ओली', short: 'के.पी ओली' },
    ]
  },
  {
    label: 'सर्लाही - क्षेत्र 4',
    tag: '🔥 Key Battle',
    candidates: [
      { id: 341549, name: 'गगन कुमार थापा', short: 'गगन थापा' },
      { id: 340974, name: 'अमरेश कुमार सिह', short: 'अमरेश कुमार' },
    ]
  },
  {
    label: 'काठमाडौं - क्षेत्र 5',
    tag: '⭐ Capital Fight',
    candidates: [
      { id: 340646, name: 'प्रदीप पौडेल', short: 'प्रदीप पौडेल' },
      { id: 340085, name: 'इश्वर पोखरेल', short: 'ईश्वर पोखरेल' },
    ]
  },
  {
    label: 'काठमाडौं - क्षेत्र 1',
    tag: '⭐ Capital Clash',
    candidates: [
      { id: 0, name: 'रवीन्द्र मिश्र', short: 'रवीन्द्र मिश्र' },
      { id: 0, name: 'प्रबल थापा', short: 'प्रबल थापा' },
    ]
  },
  {
    label: 'सुनसरी - क्षेत्र 1',
    tag: '🗳️ Close Race',
    candidates: [
      { id: 0, name: 'हर्क साम्पाङ', short: 'हर्क साम्पाङ' },
      { id: 0, name: 'गोमा तामाङ', short: 'गोमा तामाङ' },
    ]
  },
  {
    label: 'रुकुम पूर्व - क्षेत्र 1',
    tag: '🔥 PM Race',
    candidates: [
      { id: 0, name: 'पुष्पकमल दाहाल (प्रचण्ड)', short: 'प्रचण्ड' },
      { id: 0, name: 'लीलामणि गौतम', short: 'लीलामणि गौतम' },
    ]
  },
];

// Find actual candidate_ids from DB for matchups with id=0
featuredMatchups.forEach(m => {
  m.candidates.forEach(c => {
    if (!c.id) {
      const found = allCandidates.find(ac => ac.name && ac.name.includes(c.short.split(' ')[0]));
      if (found) c.id = found.candidate_id;
    }
  });
});
